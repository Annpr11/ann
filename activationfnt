import numpy as np 
import matplotlib.pyplot as pyp 

def sigmoid(X):
    return (1/(1+np.exp(-X)))
def tanh(X):
    return np.tanh(X)
def relu(X):
    return np.maximum(0,X)
x=np.linspace(-10,10,20)
y=sigmoid(x)
y1=tanh(x)
y2=relu(x)

pyp.figure(figsize=(15,10))
pyp.title("activation function ",color="red",fontsize=20)

pyp.subplot(2,2,1)
pyp.plot(x,y,label="sigmoid",color="red",linestyle="--")
pyp.scatter(x,y) 
pyp.xlabel("input")
pyp.ylabel("output")
pyp.legend()
pyp.grid()

pyp.subplot(2,2,2)
pyp.plot(x,y1,label="sigmoid",color="red",linestyle="--")
pyp.scatter(x,y1) 
pyp.xlabel("input")
pyp.ylabel("output")
pyp.legend()
pyp.grid()

pyp.subplot(2,2,3)
pyp.plot(x,y2,label="sigmoid",color="red",linestyle="--",marker="*")
pyp.xlabel("input")
pyp.ylabel("output")
pyp.legend()
pyp.grid()






